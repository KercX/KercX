local function makeToggle(text, initial, callback)
    local frameToggle = Instance.new("Frame")
    frameToggle.Size = UDim2.new(1,-16,0,36)
    frameToggle.Position = UDim2.new(0,8,0,0)
    frameToggle.BackgroundColor3 = Color3.fromRGB(45,45,45)
    frameToggle.Parent = functionsFrame
    addCorner(frameToggle,8)

    local label = Instance.new("TextLabel", frameToggle)
    label.Size = UDim2.new(0.75, -8,1,0)
    label.Position = UDim2.new(0,8,0,0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("TextButton", frameToggle)
    btn.Size = UDim2.new(0.22, -10,0.6, 0)
    btn.Position = UDim2.new(1, - (0.22 * frameToggle.AbsoluteSize.X) - 12,0.2,0)
    btn.AnchorPoint = Vector2.new(1,0)
    btn.BackgroundColor3 = initial and Color3.fromRGB(80,180,80) or Color3.fromRGB(180,80,80)
    btn.Text = initial and "ON" or "OFF"
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.TextSize = 14
    btn.Parent = frameToggle
    addCorner(btn,6)

    btn.MouseButton1Click:Connect(function()
        initial = not initial
        btn.BackgroundColor3 = initial and Color3.fromRGB(80,180,80) or Color3.fromRGB(180,80,80)
        btn.Text = initial and "ON" or "OFF"
        pcall(function() callback(initial) end)
    end)
    return frameToggle, btn
end

-- ---------- Build categories + connect functions ----------
-- Helper to switch function panel content
local function setCategoryFunctions(defs)
    clearFunctionButtons()
    for _,v in ipairs(defs) do
        -- v: {type="button"/"toggle"/"label"/"textbox", text=..., fn=..., args...}
        if v.type == "label" then
            makeLabel(v.text)
        elseif v.type == "button" then
            makeFunctionButton(v.text, v.fn)
        elseif v.type == "toggle" then
            makeLabel(v.text) -- small header
            makeToggle(v.text, v.default, v.fn)
        elseif v.type == "textbox" then
            local tb = Instance.new("TextBox")
            tb.Size = UDim2.new(1,-16,0,32)
            tb.Position = UDim2.new(0,8,0,0)
            tb.BackgroundColor3 = Color3.fromRGB(60,60,60)
            tb.TextColor3 = Color3.fromRGB(255,255,255)
            tb.Text = v.defaultText or ""
            tb.PlaceholderText = v.placeholder or ""
            tb.Font = Enum.Font.Gotham
            tb.TextSize = 16
            tb.Parent = functionsFrame
            addCorner(tb,8)
            if v.onEnter then
                tb.ClearTextOnFocus = false
                tb.FocusLost:Connect(function(enter)
                    if enter then pcall(function() v.onEnter(tb.Text) end) end
                end)
            end
        end
    end
end

