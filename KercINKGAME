-- ---------- Helpers ----------
local function addCorner(obj, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 8)
    corner.Parent = obj
    return corner
end

local function safeFindEnd()
    -- Попытка найти финишную часть по популярным именам
    local names = {"Finish", "End", "FinishPart", "EndPart", "Goal"}
    for _,n in ipairs(names) do
        local part = Workspace:FindFirstChild(n, true) -- warning: FindFirstChild(name, true) not valid; we'll search descendants
    end
    -- корректный поиск по Descendants
    for _,part in ipairs(Workspace:GetDescendants()) do
        if part:IsA("BasePart") then
            local lname = part.Name:lower()
            if lname:match("finish") or lname:match("end") or lname:match("goal") or lname:match("finishpart") or lname:match("endpart") then
                return part
            end
        end
    end
    return nil
end

