-- ---------- RunService loops: ESP / Speed / Noclip / GodMode / GlassBridge ----------
local GB_LastColors = {}
RunService.RenderStepped:Connect(function()
    -- ESP handling
    if ESP_Enabled then
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character.PrimaryPart then
                local adList = ESP_Adornments[plr]
                if not adList then
                    adList = {}
                    -- add BoxHandleAdornment to primary parts for visibility
                    local part = plr.Character.PrimaryPart
                    if part then
                        local box = Instance.new("BoxHandleAdornment")
                        box.Adornee = part
                        box.AlwaysOnTop = true
                        box.Size = part.Size
                        box.ZIndex = 10
                        box.Transparency = 0.45
                        -- color based on team if possible
                        local isSeeker = false
                        if plr.Team and tostring(plr.Team.Name):lower():find("seek") then isSeeker = true end
                        box.Color3 = isSeeker and Color3.fromRGB(255,50,50) or Color3.fromRGB(50,120,255)
                        box.Parent = part
                        table.insert(adList, box)
                    end
                    ESP_Adornments[plr] = adList
                else
                    -- refresh color/size if needed
                    for _,ad in ipairs(adList) do
                        if ad.Adornee and ad.Adornee:IsA("BasePart") then
                            local p = ad.Adornee
                            ad.Size = p.Size
                            local isSeeker = false
                            if plr.Team and tostring(plr.Team.Name):lower():find("seek") then isSeeker = true end
                            ad.Color3 = isSeeker and Color3.fromRGB(255,50,50) or Color3.fromRGB(50,120,255)
                        end
                    end
                end
            end
        end
    else
        -- remove all existing adornments (if any)
        for plr,adlist in pairs(ESP_Adornments) do
            for _,a in ipairs(adlist) do
                pcall(function() a:Destroy() end)
            end
            ESP_Adornments[plr] = nil
        end
    end

    -- Local player adjustments
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            -- Speed
            if SpeedEnabled then
                hum.WalkSpeed = SpeedValue
            else
                if hum.WalkSpeed ~= 16 then hum.WalkSpeed = 16 end
            end
            -- GodMode (AntiKill)
            if GodModeEnabled then
                if hum.Health < 0.1 then
                    pcall(function() hum.Health = math.huge end)
                else
                    pcall(function() hum.Health = math.huge end)
                end
            end
        end

        -- Noclip: set CanCollide false on all parts while enabled
        if NoclipEnabled then
            for _,part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    pcall(function() part.CanCollide = false end)
                end
            end
        else
            -- when turned off we don't automatically re-enable collisions (could interfere with game)
            -- leave it to engine / respawn to restore normal collisions
        end
    end

    -- Glass Bridge marking if enabled via _G.GB_Enabled
    if _G.GB_Enabled then
        for _,part in ipairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                local name = tostring(part.Name):lower()
                if name:find("glass") or name:find("tile") or name:find("panel") then
                    local attr = part:GetAttribute("Correct")
                    if attr ~= nil then
                        if attr == true then
                            pcall(function() part.Color = Color3.fromRGB(80,200,80) end)
                        else
                            pcall(function() part.Color = Color3.fromRGB(200,60,60) end)
                        end
                    end
                end
            end
        end
    else
        -- restore original color not attempted (game handles)
    end
end)

-- Cleanup ESP adornments when players leave/join
Players.PlayerRemoving:Connect(function(plr)
    if ESP_Adornments[plr] then
        for _,a in ipairs(ESP_Adornments[plr]) do pcall(function() a:Destroy() end) end
        ESP_Adornments[plr] = nil
    end
end)
Players.PlayerAdded:Connect(function(plr)
    -- nothing special
end)

-- Safety note: when script terminates, attempt cleanup
local function cleanupAll()
    for plr,ad in pairs(ESP_Adornments) do
        for _,a in ipairs(ad) do pcall(function() a:Destroy() end) end
    end
    ESP_Adornments = {}
end

-- Bind cleanup to character removal
LocalPlayer.AncestryChanged:Connect(function()
    cleanupAll()
end)

